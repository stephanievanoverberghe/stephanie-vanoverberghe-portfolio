{
    "name": "portfolio",
    "version": "0.1.0",
    "description": "Portfolio frontend professionnel avec Next.js App Router, React et TypeScript strict.",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "build:webpack": "next build --webpack",
        "start": "next start",
        "lint": "eslint",
        "test": "vitest",
        "test:run": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:cov": "vitest run --coverage",
        "typecheck": "tsc --noEmit",
        "check:all": "npm run lint && npm run typecheck && npm run test:run && npm run build",
        "verify": "npm run check:all"
    },
    "dependencies": {
        "framer-motion": "^12.23.22",
        "lucide-react": "^0.544.0",
        "next": "16.1.6",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "resend": "^6.9.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.3",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20.19.33",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.39.3",
        "eslint-config-next": "^16.1.6",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vitest": "^3.2.4"
    }
}
